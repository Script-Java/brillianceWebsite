# Database connection string
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=your_auth_token_here

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Used for Vercel Blob storage (media uploads)
# Store Base URL: https://qh9sj3kzmqm4euuj.public.blob.vercel-storage.com
# Store ID: store_QH9sj3kzmqm4EuUj
BLOB_READ_WRITE_TOKEN=YOUR_BLOB_TOKEN_HERE

# Email Configuration (Nodemailer)
# -----------------------------
# Required for sending emails (Gmail or custom SMTP)
EMAIL=your-email@gmail.com
# For Gmail, you MUST generate an App Password (do not use your regular password)
EMAIL_PASS=your_gmail_app_password_or_smtp_password
# Optional: Set these to use a custom SMTP service (e.g., Resend, Mailgun, SendGrid) instead of Gmail
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# Optional: The email address that receives the contact form submissions (defaults to EMAIL)
# CONTACT_RECEIVER_EMAIL=receiver-email@example.com
